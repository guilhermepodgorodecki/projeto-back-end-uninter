    {
      "name": "6. Pagamentos e Status",
      "description": "Fluxo crítico na ordem correta: Pagamento (exige pedido em RECEBIDO) → Atualização de status. Por isso o T07 fica aqui, logo após o pagamento.",
      "item": [
        {
          "name": "T06 - Processar pagamento (mock)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "var json = pm.response.json();",
                  "pm.test('Status de pagamento coerente', function () { pm.expect(['EFETIVADO','NAO_EFETIVADO']).to.include(json.status); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token_cliente}}",
                  "type": "string"
                }
